\@writefile{toc}{\contentsline {subsection}{\numberline {4.3}Full Training Run}{3}{subsection.4.3}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces Win rate (50-episode rolling average) over the full 27M-step training run. Shaded regions correspond to curriculum stages. Stage 3 (VF-8) produces a peak of 22\% before the vps=8$\to $10 transition drops performance. Stage 4 (VF-10) stabilises around 8--10\%. Stage 5 (2$\times $ VF) is too hard: win rate remains near 2--4\%.}}{4}{figure.caption.16}\protected@file@percent }
\newlabel{fig:curriculum}{{5}{4}{Win rate (50-episode rolling average) over the full 27M-step training run. Shaded regions correspond to curriculum stages. Stage 3 (VF-8) produces a peak of 22\% before the vps=8$\to $10 transition drops performance. Stage 4 (VF-10) stabilises around 8--10\%. Stage 5 (2$\times $ VF) is too hard: win rate remains near 2--4\%}{figure.caption.16}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {6}{\ignorespaces Win rate vs.\ WeightedRandom (blue) and ValueFunction (red) for key training checkpoints. VP shaping curriculum improves VF performance from 7\% (PBRS only) to 10.7\% (final model) while maintaining 66\% WR performance. Stage 5 (2$\times $ VF) provides no VF improvement but does not degrade WR performance either.}}{4}{figure.caption.17}\protected@file@percent }
\newlabel{fig:ladder}{{6}{4}{Win rate vs.\ WeightedRandom (blue) and ValueFunction (red) for key training checkpoints. VP shaping curriculum improves VF performance from 7\% (PBRS only) to 10.7\% (final model) while maintaining 66\% WR performance. Stage 5 (2$\times $ VF) provides no VF improvement but does not degrade WR performance either}{figure.caption.17}{}}
