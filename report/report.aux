\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces Final win rate (mean of last 50 episodes) for each ablation condition. Linear LR (dashed) consistently outperforms constant LR (solid). Dashed line = 25\% random baseline.}}{3}{figure.caption.12}\protected@file@percent }
