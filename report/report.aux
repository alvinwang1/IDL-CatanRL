\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces Win rate vs.\ steps for VP delta reward ablation. All conditions start from the same checkpoint. $\alpha {=}0.2$ shows the highest final win rate and fastest early learning. Dashed grey line = previous best win rate vs.\ ValueFunction ($\sim $5\%) without VP shaping.}}{3}{figure.caption.13}\protected@file@percent }
\newlabel{fig:vp_curves}{{3}{3}{Win rate vs.\ steps for VP delta reward ablation. All conditions start from the same checkpoint. $\alpha {=}0.2$ shows the highest final win rate and fastest early learning. Dashed grey line = previous best win rate vs.\ ValueFunction ($\sim $5\%) without VP shaping}{figure.caption.13}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces Final win rate by VP delta scale $\alpha $. All non-zero $\alpha $ conditions beat the no-VP baseline. $\alpha {=}0.2$ wins by the largest margin (12.0\% late average vs.\ 9.7\%).}}{3}{figure.caption.14}\protected@file@percent }
\newlabel{fig:vp_bar}{{4}{3}{Final win rate by VP delta scale $\alpha $. All non-zero $\alpha $ conditions beat the no-VP baseline. $\alpha {=}0.2$ wins by the largest margin (12.0\% late average vs.\ 9.7\%)}{figure.caption.14}{}}
